# Django (lokal)
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost

# Database — PostgreSQL (tavsiya). Bo'sh qoldirilsa lokal default (settings.py)
# Lokal Postgres (DATABASE.md ga qarang):
DATABASE_URL=postgresql://itnav:YOUR_PASSWORD@localhost:5432/it_navigator

# CORS — lokalda barcha origin
CORS_ALLOW_ALL_ORIGINS=True

# Til va vaqt
LANGUAGE_CODE=uz
TIME_ZONE=Asia/Tashkent

# Groq AI — https://console.groq.com
GROQ_API_KEY=gsk_your_key_here

# Telegram — footer xabarlari
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Production (PythonAnywhere) — serverda ~/it-navigator/.env
# DEBUG=False
# ALLOWED_HOSTS=yourusername.pythonanywhere.com
# SECURE_SSL_REDIRECT=False
# DATABASE_URL=postgresql://USER:PASS@HOST:5432/it_navigator
# CORS_ALLOW_ALL_ORIGINS=False
