# Django (lokal)
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost

# Database — lokal SQLite; Railway da PostgreSQL plugin DATABASE_URL beradi
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# CORS — production da frontend URL (vergul bilan)
# CORS_ALLOWED_ORIGINS=https://your-frontend.up.railway.app
# CSRF_TRUSTED_ORIGINS=https://your-frontend.up.railway.app
CORS_ALLOW_ALL_ORIGINS=True

# Til va vaqt
LANGUAGE_CODE=uz
TIME_ZONE=Asia/Tashkent

# Groq AI — https://console.groq.com
GROQ_API_KEY=gsk_your_key_here

# Telegram — footer xabarlari
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Railway (backend service — dashboard da qo‘ying)
# DEBUG=False
# ALLOWED_HOSTS=.up.railway.app
# RAILWAY_PUBLIC_DOMAIN=your-backend.up.railway.app
# PORT=8000
